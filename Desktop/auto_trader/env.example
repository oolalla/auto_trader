# ============================================================
# .env 파일 예시 (실제 사용 시 이 파일을 .env로 저장)
# 절대 Git에 올리지 마세요! .gitignore에 .env 추가 필수
# ============================================================

APP_KEY=**
APP_SECRET=**
ACCOUNT_NO=**
IS_PAPER=true
# IS_PAPER=true  → 모의투자 (처음엔 반드시 true로 시작)
# IS_PAPER=false → 실전투자 (충분히 테스트 후에만 변경)
